{
  "name": "db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Prisma schema, migrations, and database client for genbooks and panel_books. Shipped as TypeScript source; consumers list it in transpilePackages.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "bun prisma/seed.ts",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.21",
    "prisma": "^6.19.2",
    "typescript": "^5.9.3"
  }
}
