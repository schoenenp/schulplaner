# =============================================================================
# Combined environment template for both apps: genbooks + panel_books
#
# Copy this file to apps/genbooks/.env and apps/panel_books/.env and fill in
# the values. Both apps share most variables (same database, mail server,
# upload API, Stripe account, CDN) — only the sections marked "genbooks only"
# or "panel_books only" differ.
#
# The authoritative schemas live in apps/<app>/src/env.js. Keep this file
# up-to-date when adding variables there.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (shared — both apps and packages/db use the same database)
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://user:password@localhost:3306/schoolbooks"

# -----------------------------------------------------------------------------
# Auth (shared)
# Generate a secret with: npx auth secret
# Required in production; optional in development.
# -----------------------------------------------------------------------------
AUTH_SECRET=""
# Canonical origin of the app. Per app:
#   genbooks:    https://books.pirrot.de
#   panel_books: https://panel.books.pirrot.de
AUTH_URL=""
NEXTAUTH_URL=""
AUTH_TRUST_HOST="true"

# --- genbooks only: Google OAuth sign-in ---
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- genbooks only: origin allow-list for auth/requests (optional) ---
APP_ALLOWED_ORIGINS=""
APP_FALLBACK_ORIGIN=""

# -----------------------------------------------------------------------------
# Email / SMTP (shared — magic-link sign-in and transactional mail)
# Port 465 = implicit TLS (set EMAIL_SERVER_SECURE=true), 587 = STARTTLS.
# -----------------------------------------------------------------------------
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@yourapp.com"

# --- panel_books only ---
EMAIL_SERVER_SECURE="true"
EMAIL_SERVER_TIMEOUT_MS="10000"

# --- genbooks only: address that receives shop/order mail ---
SHOP_EMAIL="shop@yourapp.com"

# -----------------------------------------------------------------------------
# Stripe (shared account; used for coupons, invoices, fulfillment)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""

# --- genbooks only: checkout ---
NEXT_PUBLIC_STRIPE_PUSHABLE_KEY=""
STRIPE_SUCCESS_URL="https://yourapp.com/payment/success"
STRIPE_CANCEL_URL="https://yourapp.com/payment/cancel"

# --- genbooks only: Stripe Connect partner subscriptions (optional) ---
STRIPE_CONNECT_SUBSCRIPTION_MONTHLY_PRICE_ID=""
STRIPE_CONNECT_SUBSCRIPTION_YEARLY_PRICE_ID=""
STRIPE_CONNECT_APPLICATION_FEE_CENTS=""
STRIPE_CONNECT_COUNTRY=""

# -----------------------------------------------------------------------------
# Partner program (shared feature flags; optional)
# Defaults: fulfillment on outside production, settlement off.
# -----------------------------------------------------------------------------
PARTNER_CONTROLLED_FULFILLMENT_ENABLED=""
PARTNER_EU_LEGAL_TEXT=""

# --- genbooks only (optional) ---
PARTNER_SETTLEMENT_ENABLED=""
PARTNER_LINK_SECRET=""

# -----------------------------------------------------------------------------
# Upload API / CDN (shared — file storage and PDF module files)
# -----------------------------------------------------------------------------
UPLOAD_URL_LINK=""
UPLOAD_API_KEY=""
NEXT_PUBLIC_CDN_SERVER_URL="https://yourcdn.com"
CUSTOM_COVER_TEMPLATE_URL="https://yourcdn.com/storage/custom-cover-template.pdf"

# -----------------------------------------------------------------------------
# PDF pipeline (shared — grayscale conversion proxy; optional)
# -----------------------------------------------------------------------------
GHOST_GRAYSCALE_API_KEY=""

# -----------------------------------------------------------------------------
# genbooks only: misc
# -----------------------------------------------------------------------------
# Secret for signed order-cancellation links
CANCEL_SECRET=""
# PostHog analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV="development"
# Set to 1 to skip env validation (useful for Docker builds)
# SKIP_ENV_VALIDATION=1
